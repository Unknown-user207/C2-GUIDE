# Copy this file to .env and fill in the keys you plan to use.
# Any provider left blank will simply show as unavailable in the model menu.

OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_API_KEY=
DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions

# Local Ollama fallback / default model
# Default points at Ollama's hosted cloud API — get a key at https://ollama.com
OLLAMA_API_KEY=
OLLAMA_ENDPOINT=https://ollama.com/api/chat
OLLAMA_MODEL=gpt-oss:20b

# To use a local Ollama install instead, leave OLLAMA_API_KEY blank and set:
# OLLAMA_ENDPOINT=http://localhost:11434/api/chat
# OLLAMA_MODEL=llama3

# Storage locations (relative to project root)
MEMORY_DB=memory.db
CONTEXT_FILE=project_context.json
